<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/png" href="../favicon.png" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Megacinema - Dashboard</title>
  </head>

  <body>
    <header class="admin-header">
        <h1>MegaCinema Dashboard</h1>
        <div class="user-info">
            <span>Administrador</span>
            <a href="/admin/login" class="btn-logout">Cerrar Sesion</a>
        </div>
    </header>

    <main class="dashboard-main">
        <div class="dashboard-container">

            <div class="dashboard-actions">
                <a href="/admin/productos/nuevo" class="btn-primary">+ Agregar Nuevo Producto</a>
            </div>

            <% if(!productoActual || productoActual === 'todos' || productoActual === 'peliculas'){ %>
            <section class="products-section">
                <h2>Peliculas</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titulo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (peliculas.length === 0) { %>
                            <tr><td colspan="4" class="text-center">No se encontraron peliculas.</td></tr>
                        <% } %>

                        <% peliculas.forEach(pelicula => { %>
                            <tr>
                                <td><%= pelicula.id  %></td>
                                <td><%= pelicula.titulo %></td>
                                <td>
                                    <span class="badge-estado <%= pelicula.activo ? 'badge-activo' : 'badge-inactivo' %>">
                                        <%= (pelicula.activo) ? 'Activo' : 'Inactivo'%>
                                    </span>
                                </td>
                                <td class="acciones-cell">
                                    <a href="/admin/editar/pelicula/<%= pelicula.id %>" class="btn-action btn-edit">Editar</a>

                                    <% if (pelicula.activo) { %>
                                        <form method="POST" action="/admin/pelicula/desactivar/<%= pelicula.id %>">
                                            <button type="submit" class="btn-action btn-delete">Baja</button>
                                        </form>
                                    <% } else { %>
                                        <form method="POST" action="/admin/pelicula/activar/<%= pelicula.id %>">
                                            <button type="submit" class="btn-action btn-activate">Alta</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>

                        <%  }); %>
                    </tbody>
                </table>
            </section>
            <% } %>

            <% if(!productoActual || productoActual === 'todos' || productoActual === 'snacks'){ %>
            <section class="products-section">
                <h2>Snacks y Combos</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Precio</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (snacks.length === 0) { %>
                            <tr><td colspan="5" class="text-center">No se encontraron snacks.</td></tr>
                        <% } %>

                        <% snacks.forEach(snack => { %>
                            <tr>
                                <td><%= snack.id  %></td>
                                <td><%= snack.titulo %></td>
                                <td><%= `$${snack.precio}` %></td>
                                <td>
                                    <span class="badge-estado <%= snack.activo ? 'badge-activo' : 'badge-inactivo' %>">
                                        <%= (snack.activo) ? 'Activo' : 'Inactivo'%>
                                    </span>
                                </td>
                                <td class="acciones-cell">
                                    <a href="/admin/editar/snack/<%= snack.id %>" class="btn-action btn-edit">Editar</a>

                                    <% if (snack.activo) { %>
                                        <form method="POST" action="/admin/snack/desactivar/<%= snack.id %>">
                                            <button type="submit" class="btn-action btn-delete">Baja</button>
                                        </form>
                                    <% } else { %>
                                        <form method="POST" action="/admin/snack/activar/<%= snack.id %>">
                                            <button type="submit" class="btn-action btn-activate">Alta</button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>

                        <%  }); %>
                    </tbody>
                </table>
            </section>
            <% } %>
        </div>
    </main>

    <footer>
      <span>Juan Lencioni & Leandro Quinteros</span>
    </footer>
  </body>
</html>
