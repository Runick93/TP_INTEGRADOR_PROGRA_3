<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/png" href="../favicon.png" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Megacinema - Login</title>
  </head>

  <body>
    <body>

    <header class="admin-header">
        <h1>MegaCinema Back-Office</h1>
        <div class="user-info">
            <span>Administrador</span>
            <a href="/admin/login" class="btn-logout">Cerrar Sesión</a>
        </div>
    </header>

    <main class="dashboard-container">
        
        <div class="dashboard-actions">
            <form action="/admin/dashboard" method="GET" class="filter-form">
                <label for="producto">Producto:</label>
                <select name="producto" id="producto" onchange="this.form.submit()">
                    <option value="todos" <% ( !productoActual || productoActual === 'todos') ? 'selected' : ''  %>>Todos los productos</option>
                    <option value="peliculas" <%= productoActual === 'peliculas' ? 'selected' : '' %> >Peliculas</option>
                    <option value="snacks" <%= productoActual === 'snacks' ? 'selected' : '' %> >Snacks</option>
                </select>
                <label for="estado">Estado:</label>
                <select name="estado" id="estado" onchange="this.form.submit()">
                    <option value="todos"<% ( !estadoActual || estadoActual === 'todos') ? 'selected' : ''  %>>Todos los productos</option>
                    <option value="activos" <%= estadoActual === 'activos' ? 'selected' : '' %> >Solo Activos</option>
                    <option value="inactivos" <%= estadoActual === 'inactivos' ? 'selected' : '' %> >Solo Inactivos</option>
                </select>
                
            </form>

            <a href="/admin/productos/nuevo" class="btn-primary">➕ Agregar Nuevo Producto</a>
        </div>
        <% if(!productoActual || productoActual === 'todos' || productoActual === 'peliculas'){ %>
        <section class="products-section">
            <h2>Peliculas</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Título</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (peliculas.length === 0) { %>
                        <tr><td colspan="5" class="text-center">No se encontraron películas.</td></tr>
                    <% } %>
                    
                    <% peliculas.forEach(pelicula => { %>
                        <tr>
                            <td><%= pelicula.id  %></td>
                            <td><%= pelicula.titulo %></td>
                            <td><%= (pelicula.activo) ? 'Activo' : 'Inactivo'%></td>
                            <td>
                                <a href="/admin/editar/pelicula/<%= pelicula.id %>" class="btn-action btn-edit">Editar</a>
                                
                                <% if (pelicula.activo) { %>
                                    <button onclick="abrirModal('pelicula', <%= pelicula.id %>, 'desactivar')" class="btn-action btn-delete">Baja</button>
                                <% } else { %>
                                    <button onclick="abrirModal('pelicula', <%= pelicula.id %>, 'activar')" class="btn-action btn-activate">Alta</button>
                                <% } %>
                            </td>
                        </tr>
                        
                    <%  }); %>
                </tbody>
            </table>
        </section>
        <% } %>
        <% if(!productoActual || productoActual === 'todos' || productoActual === 'snacks'){ %>
        <section class="products-section">
            <h2>Snacks y Combos</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (snacks.length === 0) { %>
                        <tr><td colspan="5" class="text-center">No se encontraron películas.</td></tr>
                    <% } %>
                    
                    <% snacks.forEach(snack => { %>
                        <tr>
                            <td><%= snack.id  %></td>
                            <td><%= snack.titulo %></td>
                            <td><%= `$${snack.precio}` %></td>
                            <td><%= (snack.activo) ? 'Activo' : 'Inactivo'%></td>
                            <td>
                                <a href="/admin/editar/snack/<%= snack.id %>" class="btn-editar">Editar</a>
                                
                                <% if (snack.activo) { %>
                                    <button onclick="abrirModal('snack', <%=snack.id%>, 'desactivar')" class="btn-baja">Baja</button>
                                <% } else { %>
                                    <button onclick="abrirModal('snack', <%= snack.id %>, 'activar')" class="btn-alta">Alta</button>
                                <% } %>
                            </td>
                        </tr>
                        
                    <%  }); %>
                </tbody>
            </table>
        </section>
        <% } %>
    </main>
    
    <div id="modal-confirmacion" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h3 id="modal-titulo">Confirmar accion</h3>
            <p id="modal-mensaje">¿Estas seguro de realizar este cambio?</p>
            <div class="modal-botones">
                <button id="btn-modal-cancelar" onclick="cerrarModal()" class="btn-cancel">Cancelar</button>
                <form id="modal-form" method="POST" action=" ">
                    <button type="submit" class="btn-confirm" id="btn-modal-aceptar">Confirmar</button>
                </form>
            </div>
        </div>
    </div>
</body>

    <footer>
      <span>Juan Lencioni & Leandro Quinteros</span>
    </footer>
  </body>
  <script>
        function abrirModal(tipo, id, accion) {
        
            const modal = document.getElementById('modal-confirmacion');
            const title = document.getElementById('modal-titulo');
            const msg = document.getElementById('modal-mensaje');
            const form = document.getElementById('modal-form');

            title.innerText = accion === 'desactivar' ? 'Confirmar Baja' : 'Confirmar Alta';
            msg.innerText = `¿Estás seguro de que deseas ${accion} este producto?`;
            
            form.action = `/admin/${tipo}/${accion}/${id}`;

            modal.style.display = 'flex';
        }

        function cerrarModal() {
            document.getElementById('modal-confirmacion').style.display = 'none';
        }
    </script>
</html>

