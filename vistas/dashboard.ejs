<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/png" href="../favicon.png" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Megacinema - Dashboard</title>
  </head>

  <body>
    <header class="admin-header">
        <h1>MegaCinema Dashboard</h1>
        <div class="user-info">
            <span>Administrador</span>
            <a href="/admin/login" class="btn-logout">Cerrar Sesion</a>
        </div>
    </header>

    <main class="dashboard-main">
        <div class="dashboard-container">

            <div class="dashboard-actions">
                <a href="/admin/productos/nuevo" class="btn-primary">+ Agregar Nuevo Producto</a>
            </div>

            <% if(!productoActual || productoActual === 'todos' || productoActual === 'peliculas'){ %>
            <section class="products-section">
                <h2>Peliculas</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titulo</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (peliculas.length === 0) { %>
                            <tr><td colspan="4" class="text-center">No se encontraron peliculas.</td></tr>
                        <% } %>

                        <% peliculas.forEach(pelicula => { %>
                            <tr>
                                <td><%= pelicula.id  %></td>
                                <td><%= pelicula.titulo %></td>
                                <td>
                                    <span class="badge-estado <%= pelicula.activo ? 'badge-activo' : 'badge-inactivo' %>">
                                        <%= (pelicula.activo) ? 'Activo' : 'Inactivo'%>
                                    </span>
                                </td>
                                <td class="acciones-cell">
                                    <a href="/admin/editar/pelicula/<%= pelicula.id %>" class="btn-action btn-edit">Editar</a>

                                    <% if (pelicula.activo) { %>
                                        <button type="button" class="btn-action btn-delete" data-bs-toggle="modal" data-bs-target="#confirmAccionModal" data-action="/admin/pelicula/desactivar/<%= pelicula.id %>" data-titulo="Confirmar baja" data-mensaje="¿Está seguro de que desea eliminar este producto?" data-boton-clase="btn-delete">Baja</button>
                                    <% } else { %>
                                        <button type="button" class="btn-action btn-activate" data-bs-toggle="modal" data-bs-target="#confirmAccionModal" data-action="/admin/pelicula/activar/<%= pelicula.id %>" data-titulo="Confirmar activación" data-mensaje="¿Está seguro de que desea activar este producto?" data-boton-clase="btn-activate">Alta</button>
                                    <% } %>
                                </td>
                            </tr>

                        <%  }); %>
                    </tbody>
                </table>
            </section>
            <% } %>

            <% if(!productoActual || productoActual === 'todos' || productoActual === 'snacks'){ %>
            <section class="products-section">
                <h2>Snacks y Combos</h2>
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nombre</th>
                            <th>Precio</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (snacks.length === 0) { %>
                            <tr><td colspan="5" class="text-center">No se encontraron snacks.</td></tr>
                        <% } %>

                        <% snacks.forEach(snack => { %>
                            <tr>
                                <td><%= snack.id  %></td>
                                <td><%= snack.titulo %></td>
                                <td><%= `$${snack.precio}` %></td>
                                <td>
                                    <span class="badge-estado <%= snack.activo ? 'badge-activo' : 'badge-inactivo' %>">
                                        <%= (snack.activo) ? 'Activo' : 'Inactivo'%>
                                    </span>
                                </td>
                                <td class="acciones-cell">
                                    <a href="/admin/editar/snack/<%= snack.id %>" class="btn-action btn-edit">Editar</a>

                                    <% if (snack.activo) { %>
                                        <button type="button" class="btn-action btn-delete" data-bs-toggle="modal" data-bs-target="#confirmAccionModal" data-action="/admin/snack/desactivar/<%= snack.id %>" data-titulo="Confirmar baja" data-mensaje="¿Está seguro de que desea eliminar este producto?" data-boton-clase="btn-delete">Baja</button>
                                    <% } else { %>
                                        <button type="button" class="btn-action btn-activate" data-bs-toggle="modal" data-bs-target="#confirmAccionModal" data-action="/admin/snack/activar/<%= snack.id %>" data-titulo="Confirmar activación" data-mensaje="¿Está seguro de que desea activar este producto?" data-boton-clase="btn-activate">Alta</button>
                                    <% } %>
                                </td>
                            </tr>

                        <%  }); %>
                    </tbody>
                </table>
            </section>
            <% } %>
        </div>
    </main>

    <div class="modal fade" id="confirmAccionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="confirmAccionTitulo">Confirmar acción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body" id="confirmAccionMensaje">
                    ¿Está seguro?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <form id="formConfirmAccion" method="POST" action="">
                        <button type="submit" class="btn-action" id="confirmAccionBoton">Confirmar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <footer>
      <span>Juan Lencioni & Leandro Quinteros</span>
    </footer>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
    <script>
        const confirmAccionModal = document.getElementById('confirmAccionModal');
        confirmAccionModal.addEventListener('show.bs.modal', (event) => {
            const trigger = event.relatedTarget;
            document.getElementById('formConfirmAccion').setAttribute('action', trigger.getAttribute('data-action'));
            document.getElementById('confirmAccionTitulo').textContent = trigger.getAttribute('data-titulo');
            document.getElementById('confirmAccionMensaje').textContent = trigger.getAttribute('data-mensaje');

            const boton = document.getElementById('confirmAccionBoton');
            boton.classList.remove('btn-delete', 'btn-activate');
            boton.classList.add(trigger.getAttribute('data-boton-clase'));
        });
    </script>
  </body>
</html>
