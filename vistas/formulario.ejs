<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="icon" type="image/png" href="../favicon.png" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Megacinema - Login</title>
  </head>

  <body>
    <main class="form-container">
        <h2><%= edicion ? 'Editar Producto' : 'Agregar Producto' %></h2>
        <form action="<%= edicion ? `/admin/productos/editar/${tipoProducto}/${producto.id}` : '/admin/productos/nuevo' %>" method="POST">

            <% if (!edicion) { %>
            <div class="form-producto">
                <label for="tipo">Tipo de Producto:</label>
                <select name="tipo" id="tipo">
                    <option value="pelicula">Película</option>
                    <option value="snack">Snack / Combo</option>
                </select>
            </div>
            <% } %>
                <div class="form-producto">
                    <label for="titulo">Titulo:</label>
                    <input type="text" name="titulo" id="titulo" value="<%= producto.titulo || '' %>">
                </div>

                <div class="form-producto">
                    <label for="descripcion">Descripcion:</label>
                    <input type="text" name="descripcion" id="descripcion" value="<%= producto.descripcion || '' %>">
                </div>

                <div class="form-producto">
                    <label for="imagen">Imagen:</label>
                    <input type="text" name="imagen" id="imagen" value="<%= producto.imagen || '' %>">
                </div>

                <div class="form-producto" id="contenedor-precio" style="display: <%= (tipoProducto === 'snack') ? 'block' : 'none' %>;">
                    <label for="precio">Precio:</label>
                    <input type="text" name="precio" id="precio" value="<%= producto.precio || '' %>">
                </div>
                <button  type="submit" class="btn-save">
                <%= edicion ? 'Guardar Cambios' : 'Crear Producto' %>
            </button>
            <a href="/admin/dashboard" class="btn-cancel">Cancelar</a>
        </form>
    </main>
    <footer>
      <span>Juan Lencioni & Leandro Quinteros</span>
    </footer>
  </body>
    
<script>
    const tipoSelect = document.getElementById('tipo');
    const contenedorPrecio = document.getElementById('contenedor-precio');

    if (tipoSelect) {
        tipoSelect.addEventListener('change', (e) => {
            if (e.target.value === 'snack') {
                contenedorPrecio.style.display = 'block';
            } else {
                contenedorPrecio.style.display = 'none';
            }
        });
    }
</script>
</html>