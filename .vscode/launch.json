    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Lanzar servidor",
            "program": "${workspaceFolder}/index.js",
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "Servidor escucuhando en el puerto ([0-9]+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        }
    ]
}
